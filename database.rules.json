{
    "rules": {
        ".read": false,
        ".write": false,
        "sessions": {
            "$sessionCode": {
                ".read": true,
                ".write": "auth != null && (!data.exists() && newData.child('creatorId').val() === auth.uid || data.child('players').child(auth.uid).exists() || (data.child('status').val() === 'waiting' && newData.child('players').child(auth.uid).exists())) || (auth == null && data.exists() && data.child('status').val() === 'playing')",
                "creatorId": {
                    ".validate": "newData.isString() && newData.val().length > 0"
                },
                "code": {
                    ".validate": "newData.isString() && newData.val().length === 6"
                },
                "players": {
                    "$playerId": {
                        ".read": true,
                        ".write": "auth != null && ($playerId === auth.uid || (data.parent().parent().child('creatorId').val() === auth.uid && !newData.exists())) || (auth == null && $playerId.beginsWith('guest_') && ((!data.exists() && root.child('sessions').child($sessionCode).child('status').val() === 'waiting') || (data.exists() && data.child('isGuest').val() === true)))",
                        ".validate": "newData.hasChildren(['username', 'avatar', 'color', 'score', 'isReady', 'isConnected'])",
                        "username": {
                            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
                        },
                        "avatar": {
                            ".validate": "newData.isString()"
                        },
                        "color": {
                            ".validate": "newData.isString()"
                        },
                        "score": {
                            ".validate": "newData.isNumber()"
                        },
                        "turnsPlayed": {
                            ".validate": "newData.isNumber()"
                        },
                        "countriesGuessed": {
                            ".validate": "true"
                        },
                        "isReady": {
                            ".validate": "newData.isBoolean()"
                        },
                        "isConnected": {
                            ".validate": "newData.isBoolean()"
                        },
                        "lastSeen": {
                            ".validate": "newData.isNumber()"
                        },
                        "isGuest": {
                            ".validate": "newData.isBoolean()"
                        }
                    }
                },
                "status": {
                    ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'countdown' || newData.val() === 'playing' || newData.val() === 'finished')"
                },
                "maxPlayers": {
                    ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
                },
                "duration": {
                    ".validate": "newData.isNumber() && newData.val() > 0"
                },
                "currentTurn": {
                    ".validate": "newData.isNumber() && newData.val() >= 0"
                },
                "currentTurnState": {
                    ".validate": "true"
                },
                "guessedCountries": {
                    ".validate": "true"
                },
                "startTime": {
                    ".validate": "newData.isNumber() || newData.val() === null"
                },
                "waitingRoomStartTime": {
                    ".validate": "newData.isNumber()"
                },
                "countdownStartTime": {
                    ".validate": "newData.isNumber() || newData.val() === null"
                },
                "isOpenRoom": {
                    ".validate": "newData.isBoolean()"
                },
                "turnStartTime": {
                    ".validate": "newData.isNumber() || newData.val() === null"
                },
                "chat": {
                    ".read": true,
                    "$messageId": {
                        ".write": "auth != null && root.child('sessions').child($sessionCode).child('players').child(auth.uid).exists() || (auth == null && root.child('sessions').child($sessionCode).child('players').child(newData.child('senderId').val()).child('isGuest').val() === true)",
                        ".validate": "newData.hasChildren(['senderId', 'senderName', 'senderColor', 'content', 'timestamp']) && newData.child('content').isString() && newData.child('content').val().length > 0 && newData.child('content').val().length <= 100 && newData.child('senderName').isString() && newData.child('senderId').isString() && newData.child('senderColor').isString() && newData.child('timestamp').isNumber()"
                    }
                },
                "joinRequests": {
                    ".read": true,
                    "$playerId": {
                        ".write": "auth != null && (data.parent().parent().child('creatorId').val() === auth.uid || $playerId === auth.uid || (!data.exists() && $playerId === auth.uid)) || (auth == null && $playerId.beginsWith('guest_') && root.child('sessions').child($sessionCode).child('status').val() === 'waiting')",
                        ".validate": "newData.hasChildren(['playerId', 'username', 'avatar', 'color', 'isGuest', 'timestamp', 'status'])",
                        "status": {
                            ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected')"
                        },
                        "playerId": {
                            ".validate": "newData.isString()"
                        },
                        "username": {
                            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
                        },
                        "avatar": {
                            ".validate": "newData.isString()"
                        },
                        "color": {
                            ".validate": "newData.isString()"
                        },
                        "isGuest": {
                            ".validate": "newData.isBoolean()"
                        },
                        "timestamp": {
                            ".validate": "newData.isNumber()"
                        }
                    }
                }
            }
        },
        "activeSessions": {
            "$uid": {
                ".read": "auth != null && $uid === auth.uid",
                ".write": "auth != null && $uid === auth.uid",
                "sessionId": {
                    ".validate": "newData.isString()"
                },
                "sessionCode": {
                    ".validate": "newData.isString()"
                },
                "timestamp": {
                    ".validate": "newData.isNumber()"
                },
                "connected": {
                    ".validate": "newData.isBoolean()"
                }
            }
        }
    }
}
